// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCE
  DRIVER
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}

enum VehicleType {
  BUS
  MINIBUS
  VAN
  TRUCK
  CAR
}

enum FuelType {
  PETROL
  DIESEL
  CNG
  ELECTRIC
  HYBRID
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  SUSPENDED
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DELAYED
}

enum MaintenanceType {
  SCHEDULED
  EMERGENCY
  INSPECTION
  REPAIR
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
  INSURANCE
  TOLL
  DRIVER_SALARY
  PERMIT
  MISCELLANEOUS
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  name         String
  role         UserRole  @default(DISPATCHER)
  avatar       String?
  phone        String?
  isActive     Boolean   @default(true)
  refreshToken String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("users")
}

model Vehicle {
  id               String        @id @default(cuid())
  regNumber        String        @unique
  make             String
  model            String
  year             Int
  type             VehicleType   @default(BUS)
  fuelType         FuelType      @default(DIESEL)
  capacity         Int
  status           VehicleStatus @default(ACTIVE)
  color            String?
  vin              String?       @unique
  insuranceExpiry  DateTime?
  permitExpiry     DateTime?
  lastServiceDate  DateTime?
  nextServiceDate  DateTime?
  odometer         Float         @default(0)
  imageUrl         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  trips        Trip[]
  maintenance  Maintenance[]
  fuelLogs     FuelLog[]
  expenses     Expense[]

  @@map("vehicles")
}

model Driver {
  id              String       @id @default(cuid())
  employeeId      String       @unique
  name            String
  email           String       @unique
  phone           String
  licenseNumber   String       @unique
  licenseExpiry   DateTime
  dateOfBirth     DateTime?
  address         String?
  status          DriverStatus @default(ACTIVE)
  avatar          String?
  experience      Int          @default(0)
  totalTrips      Int          @default(0)
  rating          Float        @default(5.0)
  joiningDate     DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  trips Trip[]

  @@map("drivers")
}

model Route {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  origin      String
  destination String
  distance    Float
  duration    Int      // minutes
  stops       Json?    // array of waypoints
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trips Trip[]

  @@map("routes")
}

model Trip {
  id             String     @id @default(cuid())
  tripNumber     String     @unique
  vehicleId      String
  driverId       String
  routeId        String?
  status         TripStatus @default(SCHEDULED)
  scheduledStart DateTime
  scheduledEnd   DateTime
  actualStart    DateTime?
  actualEnd      DateTime?
  startOdometer  Float?
  endOdometer    Float?
  distance       Float?
  passengerCount Int?
  notes          String?
  currentLat     Float?
  currentLng     Float?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id])
  driver   Driver   @relation(fields: [driverId], references: [id])
  route    Route?   @relation(fields: [routeId], references: [id])
  expenses Expense[]

  @@map("trips")
}

model Maintenance {
  id            String            @id @default(cuid())
  vehicleId     String
  type          MaintenanceType   @default(SCHEDULED)
  status        MaintenanceStatus @default(PENDING)
  title         String
  description   String?
  scheduledDate DateTime
  completedDate DateTime?
  cost          Float?
  vendor        String?
  odometer      Float?
  partsReplaced String?
  technicianNote String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("maintenance")
}

model FuelLog {
  id          String   @id @default(cuid())
  vehicleId   String
  date        DateTime @default(now())
  liters      Float
  pricePerLtr Float
  totalCost   Float
  odometer    Float
  station     String?
  fuelType    FuelType @default(DIESEL)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("fuel_logs")
}

model Expense {
  id          String          @id @default(cuid())
  vehicleId   String?
  tripId      String?
  category    ExpenseCategory @default(MISCELLANEOUS)
  amount      Float
  date        DateTime        @default(now())
  description String?
  receipt     String?
  approvedBy  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  trip    Trip?    @relation(fields: [tripId], references: [id])

  @@map("expenses")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}
